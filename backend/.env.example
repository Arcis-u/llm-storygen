# Copy this file to .env and fill in your API keys
# You ONLY need the keys for the models you plan to use!

# --- API KEYS ---
# 1. Google Gemini (Easiest to get, generous free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Groq (For blazing fast Open Source models like Llama 3)
GROQ_API_KEY=your_groq_api_key_here

# 3. Anthropic (For Claude 3.5 Sonnet - Best prose quality)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 4. OpenAI (For GPT-4o / GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# --- DATABASE SETTINGS ---
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=interactive_story
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=story_memory

# --- SERVER SETTINGS ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# --- MODEL ASSIGNMENTS ---
# You can mix and match models based on your keys.
# Prefix the model name to tell the system which API to use:
# - 'gemini-...' -> Uses GEMINI_API_KEY
# - 'llama-...', 'mixtral-...' -> Uses GROQ_API_KEY
# - 'claude-...' -> Uses ANTHROPIC_API_KEY
# - 'gpt-...' -> Uses OPENAI_API_KEY

# Director: Needs high reasoning & tool calling.
# Recommended: gemini-3.1-pro, claude-3-5-sonnet-20241022, llama-3.1-70b-versatile
DIRECTOR_MODEL=gemini-3.1-pro-preview

# Writer: Needs best prose quality (Show don't tell, 5 senses).
# Recommended: gemini-3.1-pro, claude-3-5-sonnet-20241022, llama-3.1-70b-versatile
WRITER_MODEL=gemini-3.1-pro-preview

# Editor (State Extractor): Needs fast & accurate JSON extraction.
# Recommended: gemini-3.1-flash, gpt-4o-mini, llama-3.1-8b-instant
EDITOR_MODEL=gemini-3.1-flash-lite-preview

# GameMaster: Needs fast choice generation.
# Recommended: gemini-3.1-flash, gpt-4o-mini, llama-3.1-8b-instant
GAMEMASTER_MODEL=gemini-3.1-flash-lite-preview

# Embeddings: Vector search memory.
# Recommended: text-embedding-004 (Google), text-embedding-3-small (OpenAI)
EMBEDDING_MODEL=text-embedding-004
